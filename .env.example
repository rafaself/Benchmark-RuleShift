# Copy this file to `.env` or export the variables in your shell.
# Real-model runs are optional and are not part of the deterministic test gate.
# Kaggle deployment does not read `.env`; GitHub Actions deploys use the
# `KAGGLE_API_TOKEN` repository secret only.

# Gemini first-panel runner:
#   .venv/bin/python scripts/ife.py gemini-first-panel
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic panel runner:
#   .venv/bin/python scripts/ife.py anthropic-panel
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI local-only panel runner:
#   .venv/bin/python scripts/ife.py openai-panel --include-narrative --model gpt-5-mini-2025-08-07
OPENAI_API_KEY=your_openai_api_key_here
